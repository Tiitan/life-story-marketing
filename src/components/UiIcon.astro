---
interface Props {
  name:
    | 'arrow-right'
    | 'chevron-down'
    | 'check'
    | 'info'
    | 'globe'
    | 'clipboard'
    | 'profile'
    | 'list'
    | 'spark'
    | 'collaboration'
    | 'cover'
    | 'photo'
    | 'edit'
    | 'share';
